# ---------------------------------------------------------------------------
# LLM backend: "openai" (public API, default) or "azure_openai".
# Selected in one place (common/llm_client.py) and applied to every LLM call:
# query analysis, expansion, critic, generation, embeddings, and evaluation.
# ---------------------------------------------------------------------------
LLM_BACKEND=openai

# --- Public OpenAI (LLM_BACKEND=openai) ---
OPENAI_API_KEY=sk-...

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# Query analysis + expansion + retrieval critic + eval judge (cheap, fast).
# Note this model runs 4 of the 6 pipeline layers — not just the critic.
ANALYSIS_MODEL=gpt-4o-mini

# Final generation model
GENERATION_MODEL=gpt-4o

# --- Azure OpenAI (LLM_BACKEND=azure_openai) ---
# On Azure, the "model" you call is the DEPLOYMENT NAME you chose, not the
# model name. Naming each deployment after the model it serves keeps the two
# backends interchangeable.
#
# The GPT-4 family (gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini) is deprecated
# on Azure: new subscriptions cannot create deployments of it, so these are
# GPT-5-family deployments instead. text-embedding-3-small is unaffected.
# NOTE: keep comments on their own line. docker-compose reads this file with
# env_file:, and its parser does not reliably strip trailing "# ..." comments,
# so an inline comment can end up inside the value itself.
# AZURE_OPENAI_ENDPOINT=https://<name>.openai.azure.com/
# Omit the key entirely to use Managed Identity (preferred in production).
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_GPT_DEPLOYMENT=gpt-5.4-mini
# AZURE_OPENAI_ANALYSIS_DEPLOYMENT=gpt-5-mini
# AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# --- Reasoning effort (GPT-5 family only) ---
# GPT-5 models emit hidden reasoning tokens before answering. They are billed as
# output and dominate latency: a one-word classification measured 192 reasoning
# tokens vs 12 visible ones, and ran ~4x slower than with reasoning disabled.
#
# OPT-IN: leave unset and nothing is sent, which is required for non-reasoning
# models (e.g. gpt-4o on the public OpenAI backend would reject the parameter).
# Valid: minimal | low | medium | high | off
#
# "minimal" for analysis (classify/expand/critic/judge are mechanical structured
# tasks where deliberation buys nothing); "low" for generation, where some
# reasoning is worth a couple of seconds.
# REASONING_EFFORT_ANALYSIS=minimal
# REASONING_EFFORT_GENERATION=low

# ChromaDB
# ./data/chroma is only correct inside Docker (CWD=/app, ./data volume-mounted).
# Running locally with uvicorn from backend/, this must be an absolute path to
# <project_root>/data/chroma, or dense/sparse retrieval silently hits an empty DB.
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=buildcore

# Retriever backend: "local" (ChromaDB + BM25 + RRF, default) or "azure_ai_search".
RETRIEVER_BACKEND=local

# Reranker backend: "cross_encoder" (local MiniLM, default) or "passthrough".
# Use passthrough when the retriever already ranked its own results — i.e. with
# Azure AI Search + AZURE_SEARCH_SEMANTIC_CONFIG set, where the managed semantic
# ranker fills the cross-encoder's role. Passthrough keeps the pipeline's rerank
# step (and its trace/SSE shape) while making the implementation a no-op, and
# means torch is never imported.
RERANKER_BACKEND=cross_encoder

# Retrieval config
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANKED=8
QUERY_EXPANSION_COUNT=3
# Children fetched per query variant = TOP_K_DENSE × this, so enough distinct
# parents survive the small-to-big child→parent collapse.
CHILD_FETCH_MULTIPLIER=4

# Small-to-big (parent-child) chunking. Structure-aware parent chunks are split
# into small child chunks that get embedded/indexed; matches resolve back to the
# parent for generation. Children are char-capped, so ingestion never truncates.
CHILD_SENTENCES=3
CHILD_OVERLAP=1
CHILD_MAX_CHARS=1200

# Azure AI Search (production backend — only needed when RETRIEVER_BACKEND=azure_ai_search)
# The index stores child chunks pushed by ingestion/azure_index.py; the
# retriever collapses child hits back to parents, mirroring the local backend.
# AZURE_SEARCH_ENDPOINT=https://<name>.search.windows.net
# AZURE_SEARCH_INDEX=buildcore
# Omit the key entirely to use Managed Identity (preferred in production).
# AZURE_SEARCH_API_KEY=
# Enables the managed semantic ranker. Must match the semantic configuration
# name created by ingestion/azure_index.py, and the ranker must be turned on
# for the service (portal: Search service -> Semantic ranker -> Free).
# AZURE_SEARCH_SEMANTIC_CONFIG=buildcore-semantic
# AZURE_SEARCH_VECTOR_FIELD=contentVector
# AZURE_SEARCH_PARENT_ID_FIELD=parent_id
# Width of text-embedding-3-small.
# AZURE_SEARCH_VECTOR_DIMENSIONS=1536

# Corpus data directory for ingestion.
# Set to /app/data/raw when running inside Docker; omit when running locally
# (the pipeline falls back to <project_root>/data/raw automatically).
DATA_DIR=/app/data/raw

# Evaluation
EVAL_SUITE_PATH=./evaluation/test_suite.json
TRACES_DIR=./traces
