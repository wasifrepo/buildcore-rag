# OpenAI
OPENAI_API_KEY=sk-...

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# Query analysis + retrieval critic model (cheap, fast)
ANALYSIS_MODEL=gpt-4o-mini

# Final generation model
GENERATION_MODEL=gpt-4o

# ChromaDB
# ./data/chroma is only correct inside Docker (CWD=/app, ./data volume-mounted).
# Running locally with uvicorn from backend/, this must be an absolute path to
# <project_root>/data/chroma, or dense/sparse retrieval silently hits an empty DB.
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=buildcore

# Retrieval config
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANKED=8
QUERY_EXPANSION_COUNT=3

# Corpus data directory for ingestion.
# Set to /app/data/raw when running inside Docker; omit when running locally
# (the pipeline falls back to <project_root>/data/raw automatically).
DATA_DIR=/app/data/raw

# Evaluation
EVAL_SUITE_PATH=./evaluation/test_suite.json
TRACES_DIR=./traces
